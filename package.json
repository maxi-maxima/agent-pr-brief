{
  "name": "agent-pr-brief",
  "version": "0.1.0",
  "description": "Generate deterministic review briefs for AI-agent pull requests.",
  "type": "module",
  "bin": {
    "agent-pr-brief": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md",
    "CHANGELOG.md",
    "CHANGELOG.zh-CN.md",
    "CONTRIBUTING.md",
    "CONTRIBUTING.zh-CN.md",
    "SECURITY.md",
    "SECURITY.zh-CN.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "node -e \"fs.rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.test.json",
    "check": "npm run lint && npm run test && npm run typecheck && npm run build",
    "prepack": "npm run check"
  },
  "keywords": [
    "ai-agents",
    "pull-request",
    "code-review",
    "git-diff",
    "review-tools",
    "cli",
    "developer-tools"
  ],
  "author": "maxi-maxima",
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.2",
    "picocolors": "^1.1.1",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.0.3",
    "eslint": "^9.39.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.49.0",
    "vitest": "^4.0.15"
  },
  "engines": {
    "node": ">=20"
  }
}
